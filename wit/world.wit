package sqlite:extension@0.1.0;

/// Minimal extension — read-only SQL + scalar functions. Suitable for
/// stateless pure functions: text transforms, math, hashing.
world minimal {
    import types;
    import spi;
    import logging;
    import config;

    export metadata;
    export scalar-function;
}

/// Stateful extension — adds aggregate functions, host-managed state,
/// and an in-memory cache.
world stateful {
    import types;
    import spi;
    import logging;
    import config;
    import state;
    import cache;

    export metadata;
    export scalar-function;
    export aggregate-function;
}

/// Extension with full lifecycle awareness. Builds on `stateful` by
/// adding prepared statements (for setup queries in on-load) and the
/// lifecycle export.
world lifecycle-aware {
    import types;
    import spi;
    import prepared;
    import logging;
    import config;
    import state;
    import cache;

    export metadata;
    export lifecycle;
    export scalar-function;
    export aggregate-function;
}

/// Extension that authorizes SQL actions.
world authorizing {
    import types;
    import spi;
    import logging;
    import config;

    export metadata;
    export authorizer;
}

/// Extension that observes row-level changes and transaction boundaries.
world hooked {
    import types;
    import spi;
    import logging;
    import config;

    export metadata;
    export update-hook;
    export commit-hook;
}

/// Full-featured extension — every host capability available, every
/// guest hook offered. Use this when an extension genuinely needs the
/// kitchen sink; prefer a narrower world otherwise.
world full {
    import types;
    import spi;
    import prepared;
    import transaction;
    import schema;
    import logging;
    import config;
    import state;
    import cache;
    import random;
    import text;
    import hashing;
    import encoding;

    export metadata;
    export lifecycle;
    export scalar-function;
    export aggregate-function;
    export collation;
    export authorizer;
    export update-hook;
    export commit-hook;
}
